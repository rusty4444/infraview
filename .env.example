# InfraView — Service Configuration
# Copy this file to .env and fill in your values.
# These are only used to seed the database on first run.

NETDATA_URL=http://192.168.1.100:19999
UPTIMEKUMA_URL=http://192.168.1.100:3001
UPTIMEKUMA_API_KEY=your_uptime_kuma_prometheus_api_key
BACKREST_URL=http://192.168.1.100:9898
BACKREST_USERNAME=your_backrest_username
BACKREST_PASSWORD=your_backrest_password
UNIFI_URL=https://192.168.1.1
UNIFI_API_KEY=your_unifi_api_key
